{
  "name": "voidwalker-mcp",
  "version": "1.0.2",
  "description": "Local MCP server for Voidwalker — streams browser storage, cookies, and DOM mutations to AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "voidwalker-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --outDir dist --external @modelcontextprotocol/sdk --external ws",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["mcp", "browser", "localstorage", "indexeddb", "ai", "claude", "cursor", "devtools"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohi-devhub/voidwalker"
  },
  "homepage": "https://github.com/mohi-devhub/voidwalker"
}
